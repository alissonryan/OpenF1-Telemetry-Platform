# ===========================================
# F1 Telemetry Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# API Configuration
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000

# ===========================================
# Frontend Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ===========================================
# OpenF1 API
# ===========================================
OPENF1_BASE_URL=https://api.openf1.org/v1

# ===========================================
# Fast-F1 Configuration
# ===========================================
FASTF1_CACHE_DIR=./data/cache/fastf1

# ===========================================
# ML Models
# ===========================================
MODELS_DIR=./packages/ml-models

# ===========================================
# Database (Optional - Future)
# ===========================================
# DATABASE_URL=postgresql://user:password@localhost:5432/f1telemetry

# ===========================================
# Redis (Optional - Future)
# ===========================================
# REDIS_URL=redis://localhost:6379

# ===========================================
# Monitoring (Optional)
# ===========================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# POSTHOG_KEY=phc_xxx
