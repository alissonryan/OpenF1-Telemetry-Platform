# ===========================================
# F1 Telemetry API - Environment Variables
# ===========================================

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# OpenF1 API
OPENF1_BASE_URL=https://api.openf1.org/v1

# Fast-F1
FASTF1_CACHE_DIR=./data/cache/fastf1

# ML Models
MODELS_DIR=./packages/ml-models

# Redis (optional)
REDIS_URL=

# Debug mode
DEBUG=false
